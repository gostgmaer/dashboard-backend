# =====================================================================
# ENVIRONMENT VARIABLES — Essential Infrastructure Only
# =====================================================================
# Most application settings are now managed in the database via the
# admin dashboard (Platform Settings). The seed script populates
# defaults from these env vars on first run, then the DB takes over.
#
# Only ESSENTIAL variables that are needed BEFORE the database
# connects remain here.
# =====================================================================

# =======================================
# Application (ESSENTIAL)
# =======================================
NODE_ENV=development
PORT=3500
APP_URL=http://localhost:3500/api
APP_VERSION=1.0.0

# =======================================
# Database (ESSENTIAL — needed to connect)
# =======================================
MONGODB_URI=
DATABASE_URL=

DB_MAX_POOL_SIZE=20
DB_MIN_POOL_SIZE=5
DB_MAX_IDLE_TIME=30000
DB_SERVER_SELECTION_TIMEOUT=5000
DB_SOCKET_TIMEOUT=60000
DB_CONNECT_TIMEOUT=10000
DB_RETRY_WRITES=true
DB_RETRY_READS=true
DB_AUTO_INDEX=false
DB_WRITE_CONCERN=majority
DB_WRITE_TIMEOUT=10000
DB_READ_PREF=primaryPreferred
DB_COMPRESSORS=zlib
DB_AUTH_SOURCE=admin
DB_SSL=true
DB_SSL_VALIDATE=true
DB_TLS_ALLOW_INVALID_CERTS=false

# =======================================
# Security & Auth (ESSENTIAL — too sensitive for DB)
# =======================================
SESSION_SECRET=
BCRYPT_ROUNDS=12
OTP_SECRET=

JWT_SECRET=
JWT_ID_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d
JWT_ID_EXPIRY=30d
JWT_ALGORITHM=HS256
JWT_ISSUER=System Admin
JWT_AUDIENCE=users

# =======================================
# Tenant Identifier
# =======================================
NEXT_PUBLIC_SITEKEY=my-store-001

# =====================================================================
# MIGRATED TO DATABASE SETTINGS
# =====================================================================
# The following variables are now managed via Platform Settings in the
# database. They are read from the DB settings cache at runtime.
# On first deployment, the seed script uses these env values as initial
# defaults if set. After that, update them from the admin dashboard.
# =====================================================================

# --- Frontend / Client URLs → DB: client.* ---
# CLIENT_URL=http://localhost:3000
# CLIENT_LOGIN_PAGE=auth/signin
# CLIENT_RESET_PASSWORD_URL=auth/reset-password
# CLIENT_EMAIL_VERIFY_URL=auth/verify-email

# --- CORS → DB: security.allowedOrigins ---
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Email / SMTP → DB: email.* ---
# EMAIL_NAME=
# EMAIL_SERVICE=smtp
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=
# EMAIL_PASS=
# FROM_EMAIL=
# OAUTH2_CLIENT_ID=
# OAUTH2_CLIENT_SECRET=
# OAUTH2_REFRESH_TOKEN=
# OAUTH2_REDIRECT_URI=
# FALLBACK_EMAIL_SERVICE=
# FALLBACK_EMAIL_HOST=
# FALLBACK_EMAIL_PORT=587
# FALLBACK_EMAIL_USER=
# FALLBACK_EMAIL_PASS=
# EMAIL_POOL=true
# EMAIL_MAX_CONNECTIONS=5
# EMAIL_MAX_MESSAGES=100
# EMAIL_DEBUG=false

# --- Payments → DB: payment.stripe.*, payment.paypal.*, payment.razorpay.* ---
# PAYMENT_ENCRYPTION_KEY=
# STRIPE_ENABLED=false
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# PAYPAL_ENABLED=false
# PAYPAL_MODE=sandbox
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_WEBHOOK_ID=
# RAZORPAY_ENABLED=false
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# --- Storage → DB: storage.* ---
# STORAGE_TYPE=local
# LOCAL_STORAGE_PATH=uploads
# AZURE_CONTAINER=
# AZURE_ACCOUNT=
# AZURE_ACCESS_KEY=
# AZURE_CONNECTION_STRING=
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# GCS_BUCKET=
# GCS_PROJECT_ID=
# GCS_CLIENT_EMAIL=
# GCS_PRIVATE_KEY=

# --- Services → DB: services.* ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# MAILCHIMP_API_KEY=
# MAILCHIMP_LIST_ID=
# GOOGLE_CLIENT_ID=
# GOOGLE_PLACES_API_KEY=
# FACEBOOK_APP_ID=
# GITHUB_CLIENT_ID=
# APPLE_CLIENT_ID=
# TWITTER_API_KEY=
# TWITTER_API_SECRET=

# --- OTP → DB: otp.* ---
# ENABLE_OTP_VERIFICATION=false
# DEFAULT_OTP_METHOD=email
# OTP_EXPIRY_MINUTES=5
# OTP_MAX_ATTEMPTS=3

# --- Business → DB: business.* ---
# COMPANY_NAME=Your Store
# BRAND_NAME=Your Store
# CURRENCY=USD

# --- Features → DB: features.* ---
# SOCKETING_ENABLED=false
